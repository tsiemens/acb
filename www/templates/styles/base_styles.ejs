<style>
:root {
  --primary-color: #4a6fa5;
  --table-header-bg: #ededed;
  --table-cell-border-color: #999;
  --primary-color-hover: #3b5998;
  --secondary-color: #6c757d;
  --secondary-color-hover: #5a6268;
  --success-color: #28a745;
  --light-color: #f8f9fa;
  --dark-color: #343a40;
  --border-radius: 8px;
}

* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}


/* Tooltip container */
.tooltip {
  border-bottom: 1px dotted black; /* If you want dots under the hoverable text */
}

/* Tooltip text */
.tooltip .tooltiptext {
   visibility: hidden;
   width: 140pt;
   padding: 8pt;
   background-color: var(--dark-color);
   color: #fff;
   font-size: 10pt;
   text-align: center;
   border-radius: 6px;

   /* Position the tooltip text - see examples below! */
   position: absolute;
   z-index: 1;
}

/* Show the tooltip text when you mouse over the tooltip container */
.tooltip:hover .tooltiptext {
  visibility: visible;
}


.btn {
  padding: 10px 20px;
  border: none;
  border-radius: 4px;
  cursor: pointer;
  font-weight: 500;
  transition: background-color 0.2s;
}
.btn[disabled=true],
.btn:hover[disabled=true] {
   filter: saturate(0.2) brightness(1.8);
}

.btn-primary {
  background-color: var(--primary-color);
  color: white;
}
.btn-primary:hover {
  background-color: var(--primary-color-hover);
}
.btn-primary:hover[disabled=true] {
  /* Avoid color change on hover while disabled */
  background-color: var(--primary-color);
}

.btn-secondary {
  background-color: var(--secondary-color);
  color: white;
}
.btn-secondary:hover {
  background-color: var(--secondary-color-hover);
}
.btn-secondary:hover[disabled=true] {
  /* Avoid color change on hover while disabled */
  background-color: var(--secondary-color);
}

.btn-skinny {
   padding-left: 8px;
   padding-right: 8px;
   padding-top: 5px;
   padding-bottom: 5px;
}

.checkbox-container {
  display: flex;
  align-items: center;
  gap: 5px;
}

.checkbox-container label {
  margin-left: 10px;
}

.form-group {
  margin-bottom: 16px;
}

.form-group label {
  display: block;
  margin-bottom: 4px;
  font-weight: 500;
  color: #374151;
  font-size: 14px;
}

.form-group input, .form-group select {
  width: 100%;
  padding: 8px 12px;
  border: 1px solid #d1d5db;
  border-radius: 6px;
  font-size: 14px;
  background: white;
  transition: border-color 0.2s ease;
}

.form-group input:focus, .form-group select:focus {
  outline: none;
  border-color: #3b82f6;
  box-shadow: 0 0 0 3px rgba(59, 130, 246, 0.1);
}

.security-errors {
  border: 1px solid #f5c6cb;
  background: #fbe6e7;
  border-radius: 5px;
  padding: 10px;
  margin-bottom: 10px;
}

.security-notes {
  border: 1px solid #c7c7c7;
  background: #f9f9f9;
  border-radius: 5px;
  padding: 10px;
  margin-top: 5px;
}

.table-title {
  padding-left: 8px;
  background: var(--dark-color);
  color: white;
  border-radius: 5px;
  margin-bottom: 5px;
  margin-top: 20px;
  font-weight: bold;
}

.table-fixed-head {
  overflow-y: auto;
  max-height: 500px;
}
.table-fixed-head thead th {
  position: sticky;
  top: 0;
}
.table-fixed-head table {
  border-collapse: collapse;
  width: 100%;
}
.table-fixed-head th,
.table-fixed-head td {
  padding: 8px 16px;
  font-size: 9pt;
}
.table-fixed-head th {
  background: var(--table-header-bg);
  color: black;
  z-index: 1;
}
.table-fixed-head td {
  box-shadow: inset 1px 1px var(--table-cell-border-color);
}
.table-fixed-head th {
  box-shadow: inset 1px 1px var(--table-cell-border-color);
}
.table-fixed-head thead {
  box-shadow: inset 0px -1px var(--table-cell-border-color);
}
.table-fixed-head table {
  border-right: solid 1px var(--table-cell-border-color);
  border-bottom: solid 1px var(--table-cell-border-color);
}

</style>