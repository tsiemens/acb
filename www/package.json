{
    "name": "acb-web-gui",
    "version": "1.0.0",
    "description": "A web interface for ACB",
    "type": "module",
    "scripts": {
        "render-templates": "node render.cjs",
        "typecheck": "tsc --noEmit",
        "build-ts": "vite build",
        "watch-ts": "vite build --watch",
        "static-dist-link": "make static-dist-link",
        "wasm-pkg": "make wasm-pkg",
        "clean": "make clean",
        "pre-build": "npm install && npm run wasm-pkg && npm run static-dist-link",
        "build": "npm run render-templates && npm run typecheck && npm run build-ts",
        "vite-dev": "vite",
        "lint": "eslint . --ext .ts",
        "lint:fix": "eslint . --ext .ts --fix",
        "serve": "http-server -o / dist",
        "all": "npm run pre-build && npm run lint && npm run build"
    },
    "dependencies": {
        "jszip": "^3.10.1",
        "papaparse": "^5.5.3",
        "vue": "^3.5.29"
    },
    "devDependencies": {
        "@types/papaparse": "^5.5.2",
        "@typescript-eslint/eslint-plugin": "^8.57.0",
        "@typescript-eslint/parser": "^8.57.0",
        "@vitejs/plugin-vue": "^6.0.5",
        "ejs": "^3.1.10",
        "eslint": "^9.26.0",
        "eslint-plugin-import": "^2.31.0",
        "http-server": "^14.1.1",
        "terser": "^5.42.0",
        "typescript": "^5.9.3",
        "vite": "^8.0.0"
    }
}
