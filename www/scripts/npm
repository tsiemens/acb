#!/usr/bin/env bash
# Wrapper around npm that activates the correct Node version via fnm.
# fnm reads the .node-version file in this directory to select the version.
set -e

SCRIPTS_DIR="$(cd "$(dirname "$0")" && pwd)"
WWW_DIR="$(dirname "$SCRIPTS_DIR")"

# fnm is typically installed to ~/.cargo/bin
export PATH="$HOME/.cargo/bin:$PATH"

if command -v fnm &>/dev/null; then
    eval "$(fnm env --shell bash)"
    cd "$WWW_DIR" && fnm use --silent-if-unchanged
elif ! command -v npm &>/dev/null; then
    echo "error: Neither fnm nor npm found. Install fnm with: cargo install fnm" >&2
    exit 1
fi

exec npm "$@"
